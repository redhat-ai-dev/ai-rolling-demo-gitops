{
  "name": "ai-rolling-demo-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright TypeScript tests for AI Rolling Demo",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
